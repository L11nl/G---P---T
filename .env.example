# =============================================
# Telegram Bot Configuration
# =============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated list of allowed Telegram user IDs (for security)
# Leave empty to allow all users (NOT recommended)
ALLOWED_USER_IDS=123456789,987654321

# =============================================
# Cloudflare Temp Email Service
# =============================================
EMAIL_WORKER_URL=https://your-worker.workers.dev
EMAIL_DOMAIN=your-domain.com
EMAIL_PREFIX_LENGTH=10
EMAIL_WAIT_TIMEOUT=120
EMAIL_POLL_INTERVAL=3
EMAIL_ADMIN_PASSWORD=your-admin-password

# =============================================
# Registration Settings
# =============================================
TOTAL_ACCOUNTS=1
MIN_AGE=20
MAX_AGE=40
BATCH_INTERVAL_MIN=5
BATCH_INTERVAL_MAX=15

# =============================================
# Password Settings
# =============================================
PASSWORD_LENGTH=16

# =============================================
# Payment / Credit Card (for Plus subscription)
# =============================================
CARD_NUMBER=your-card-number
CARD_EXPIRY=MMYY
CARD_EXPIRY_MONTH=MM
CARD_EXPIRY_YEAR=YYYY
CARD_CVC=XXX

# =============================================
# Browser Settings
# =============================================
MAX_WAIT_TIME=600
SHORT_WAIT_TIME=120
HTTP_MAX_RETRIES=5
HTTP_TIMEOUT=30
ERROR_PAGE_MAX_RETRIES=5
BUTTON_CLICK_MAX_RETRIES=3

# =============================================
# Output File
# =============================================
ACCOUNTS_FILE=registered_accounts.txt
